# ── Spotify API Credentials ──
# Required for Spotify machine learning algorithms, recommendations, and mood processing
SPOTIFY_CLIENT_ID='your_spotify_client_id_here'
SPOTIFY_CLIENT_SECRET='your_spotify_client_secret_here'
SPOTIFY_REDIRECT_URI='http://localhost:8888/callback'

# ── Multi-LLM / AI Configuration ──

# Google Gemini API Key (Fallback or primary if Ollama is disabled)
GEMINI_API_KEY='your_gemini_api_key_here'

# ── Local / Cloud Ollama Config ──
# To use an OpenAI-compatible endpoint or an Ollama backend for the M!scenario and M!ask commands
USE_OLLAMA_FOR_SCENARIO=true
OLLAMA_API_KEY='your_ollama_api_key_here'
OLLAMA_MODEL='gemma4:31b-cloud'
OLLAMA_BASE_URL='https://ollama.com/v1/chat/completions'

# ── Theming ──
# The active UI theme. Change this in the app using the `M!theme <name>` command.
TUNECLI_THEME='cyberpunk'
